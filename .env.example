DJANGO_ENV=local
DEBUG=true
SECRET_KEY=change-me
ENABLE_PRESENCE_BOT=false

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Alias also supported by the backend:
# MONGO_DB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_USE_TLS=true
MONGO_DB_NAME=renblood_dev
# Production: renblood_mongo
# Staging: renblood_mongo_staging

ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

API_KEY_RENBLOOD=change-me
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_ID=
FRONTEND_URL=http://localhost:5173
